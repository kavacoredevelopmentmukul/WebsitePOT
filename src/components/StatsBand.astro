---
const stats = [
  'Since 2015',
  '500+ professionals placed',
  '12+ countries served',
  '96% client retention',
  '150+ skill domains',
];
---

<section class="bg-[#1B3A5C] py-6">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:flex-wrap lg:flex-nowrap items-center justify-center gap-2 sm:gap-3 md:gap-4">
      {stats.map((stat, index) => (
        <>
          <p class="text-white text-sm md:text-base font-[var(--font-body)] font-semibold tracking-normal text-center whitespace-nowrap">
            {stat}
          </p>
          {index < stats.length - 1 && (
            <span class="hidden sm:inline-block text-white/80 font-[var(--font-body)]" aria-hidden="true">|</span>
          )}
        </>
      ))}
    </div>
  </div>
</section>

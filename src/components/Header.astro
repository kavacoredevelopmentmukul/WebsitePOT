---
import ThemeToggle from './ThemeToggle.tsx';
import Logo from './Logo.astro';
import PacificClock from './PacificClock.tsx';
import { servicePillars } from '../data/services';
import { path } from '../utils/paths';
import { ChevronDown } from 'lucide-astro';

const calendlyUrl = 'https://calendly.com/pacificoceantech/15min';
---

<!-- Utility bar -->
<div class="hidden lg:block bg-[var(--navy-deep)] text-[var(--cream)] text-xs border-b border-[rgba(244,239,230,0.1)]">
  <div class="pot-container py-2.5 flex items-center justify-between">
    <PacificClock client:load />
    <div class="flex items-center gap-4">
      <a href="tel:+15551234567" class="hover:text-[#E8593C] transition-colors" aria-label="Call us at +1 555 123 4567">+1 (555) 123-4567</a>
      <a href="mailto:hello@pacificoceantech.com" class="hover:text-[#E8593C] transition-colors" aria-label="Email hello@pacificoceantech.com">hello@pacificoceantech.com</a>
    </div>
  </div>
</div>

<header class="sticky top-0 z-50 w-full bg-[var(--paper)] dark:bg-[var(--bg-primary)] border-b border-[var(--hairline)]">
  <div class="pot-container">
    <div class="flex items-center justify-between h-20">
      <div class="flex-shrink-0 flex items-center">
        <a href={path('/')} class="group transform transition-transform duration-300 hover:-translate-y-0.5" aria-label="Pacific Ocean Tech home">
          <Logo size="md" />
        </a>
      </div>

      <nav class="hidden lg:flex items-center justify-end flex-1 ml-6 gap-0.5 xl:gap-2" aria-label="Main navigation">
        <a href={path('/')} class="px-2.5 py-2 text-[13px] font-medium whitespace-nowrap transition-colors hover:text-[#E8593C] text-[var(--text-primary)]">Home</a>
        <a href={path('about')} class="px-2.5 py-2 text-[13px] font-medium whitespace-nowrap transition-colors hover:text-[#E8593C] text-[var(--text-primary)]">About Us</a>

        <div class="group inline-block relative">
          <a href={path('services')} class="flex items-center gap-1 px-2.5 py-2 text-[13px] font-medium whitespace-nowrap transition-colors hover:text-[#E8593C] text-[var(--text-primary)]" aria-haspopup="true">
            Services <ChevronDown class="w-4 h-4 transition-transform group-hover:rotate-180" aria-hidden="true" />
          </a>
          <div class="absolute left-1/2 -translate-x-1/2 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 w-screen max-w-5xl">
            <div class="ve-card p-8 grid grid-cols-3 gap-8">
              {servicePillars.map((pillar) => (
                <div>
                  <h3 class="font-bold text-lg mb-4 text-[var(--navy)] dark:text-[var(--color-accent)] border-b border-black/5 dark:border-white/5 pb-2">{pillar.title}</h3>
                  <ul class="space-y-2">
                    {pillar.categories.map((cat) => (
                      <li>
                        <a href={path(`services/${cat.id}`)} class="text-sm text-[var(--text-muted)] hover:text-[#E8593C] transition-colors flex items-center gap-2">
                          <cat.icon class="w-4 h-4" aria-hidden="true" /> {cat.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>

        <a href={path('testimonials')} class="px-2.5 py-2 text-[13px] font-medium whitespace-nowrap transition-colors hover:text-[#E8593C] text-[var(--text-primary)]">Testimonials</a>
        <a href={path('blog')} class="px-2.5 py-2 text-[13px] font-medium whitespace-nowrap transition-colors hover:text-[#E8593C] text-[var(--text-primary)]">Blog</a>
        <a href={path('contact')} class="px-2.5 py-2 text-[13px] font-medium whitespace-nowrap transition-colors hover:text-[#E8593C] text-[var(--text-primary)]">Contact Us</a>

        <div class="flex items-center gap-3 pl-4 border-l border-[var(--text-muted)]/20 ml-2 shrink-0">
          <ThemeToggle client:load />
          <a
            href={calendlyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="px-4 py-2 rounded-md border border-[var(--navy)] text-[var(--navy)] dark:border-[var(--cream)] dark:text-[var(--cream)] font-medium text-[13px] whitespace-nowrap hover:bg-[var(--navy)] hover:text-white dark:hover:bg-[var(--cream)] dark:hover:text-[var(--navy)] transition-colors"
            aria-label="Book a 15-minute call on Calendly"
          >
            Book a Call
          </a>
          <a href={path('contact')} class="px-4 py-2 rounded-md bg-[#E8593C] text-white font-medium text-[13px] whitespace-nowrap hover:bg-[#cf4b31] transition-colors">
            Get Started
          </a>
        </div>
      </nav>

      <div class="flex items-center lg:hidden gap-4">
        <ThemeToggle client:load />
        <button type="button" class="mobile-menu-button p-2 rounded-md text-[var(--text-primary)] hover:bg-[var(--bg-surface)] focus:outline-none focus:ring-2 focus:ring-[#E8593C]" aria-controls="mobile-menu" aria-expanded="false" aria-label="Open main menu">
          <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="lg:hidden hidden mobile-menu bg-[var(--bg-primary)] border-b border-black/5 dark:border-white/5 absolute w-full max-h-[80vh] overflow-y-auto z-50" id="mobile-menu">
    <div class="px-4 pt-2 pb-6 space-y-1 shadow-xl">
      <a href={path('/')} class="block px-3 py-2 rounded-md text-base font-medium text-[var(--text-primary)]">Home</a>
      <a href={path('about')} class="block px-3 py-2 rounded-md text-base font-medium text-[var(--text-primary)]">About Us</a>
      <a href={path('services')} class="block px-3 py-2 rounded-md text-base font-medium text-[var(--text-primary)]">Services</a>
      <a href={path('case-studies')} class="block px-3 py-2 rounded-md text-base font-medium text-[var(--text-primary)]">Case Studies</a>
      <a href={path('testimonials')} class="block px-3 py-2 rounded-md text-base font-medium text-[var(--text-primary)]">Testimonials</a>
      <a href={path('contact')} class="block px-3 py-2 rounded-md text-base font-medium text-[var(--text-primary)]">Contact Us</a>
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full text-center px-5 py-3 rounded-md border border-[var(--navy)] text-[var(--navy)] dark:border-[var(--cream)] dark:text-[var(--cream)] font-medium mt-4 hover:bg-[var(--navy)] hover:text-white transition-colors"
        aria-label="Book a 15-minute call on Calendly"
      >Book a 15-min Call</a>
      <a href={path('contact')} class="block w-full text-center px-5 py-3 rounded-md bg-[#E8593C] text-white font-medium mt-2">Get Started</a>
    </div>
  </div>
</header>

<script>
  const btn = document.querySelector('.mobile-menu-button');
  const menu = document.querySelector('.mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>

---
---

<section class="relative min-h-[85vh] flex flex-col items-center justify-center overflow-hidden bg-[#111827]">
  <!-- Full bleed background image -->
  <div class="absolute inset-0 -z-10">
    <img src="/images/ve_hero_bg.png" alt="Remote tech team working" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-[#111827]/90 via-[#111827]/70 to-[#111827]/40"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full flex flex-col items-start justify-center flex-grow py-20">
    <div class="max-w-4xl">
      <h1 class="text-5xl md:text-7xl lg:text-[5rem] font-extrabold tracking-tight mb-8 text-white leading-[1.1]">
        Hire Virtual Employee For Any Role
      </h1>
      
      <p class="text-xl md:text-2xl text-gray-200 mb-12 leading-relaxed max-w-3xl font-medium">
        A remote hiring ecosystem shaped over 18 years, supporting businesses across domains, skills, time zones, and stages of growth.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-5">
        <a href="/contact" class="px-8 py-4 rounded-full bg-[var(--color-accent)] text-[#111827] font-bold text-lg hover:bg-[var(--color-accent-glow)] transition-colors inline-flex items-center justify-center">
          Get Started
        </a>
        <a href="/services" class="px-8 py-4 rounded-full border border-white text-white font-bold text-lg hover:bg-white hover:text-[#111827] transition-colors inline-flex items-center justify-center">
          Explore All Services
        </a>
      </div>
    </div>
  </div>
</section>

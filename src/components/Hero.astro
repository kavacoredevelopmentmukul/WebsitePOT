---
import { path } from '../utils/paths';
import { companyStats } from '../data/company-stats';

const heroImage = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/images/hero-team.jpg`;
---

<section
  class="relative min-h-[min(88vh,720px)] flex flex-col justify-end overflow-hidden bg-cover bg-center"
  style={`background-image: url('${heroImage}')`}
  aria-label="Hero"
>
  <div class="absolute inset-0 bg-black/65" aria-hidden="true"></div>

  <div class="pot-container relative z-10 w-full pb-[clamp(3rem,8vw,5rem)] pt-32">
    <div class="max-w-3xl">
      <p class="eyebrow eyebrow-cream mb-6">Pacific Ocean Tech — Est. {companyStats.establishedYear}</p>
      <h1 class="display-lg text-[var(--cream)] mb-6 max-w-[14ch]">
        Hire dedicated remote professionals across the Pacific region
      </h1>

      <p class="lede text-[rgba(244,239,230,0.85)] mb-10 max-w-xl">
        Pre-vetted talent in IT, marketing, finance, design, and {companyStats.skillDomains} domains. At {companyStats.costSavings} less cost.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href={path('contact')} class="btn btn-primary">
          Get Started — Free Consultation
        </a>
        <a href={path('services')} class="btn btn-ghost-cream">
          View Our Services
        </a>
      </div>
    </div>
  </div>
</section>

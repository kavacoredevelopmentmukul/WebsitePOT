<section class="relative min-h-[85vh] flex flex-col items-center justify-center overflow-hidden bg-[#111827]">
  <!-- Full bleed background image -->
  <div class="absolute inset-0 -z-10">
    <img
      src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?auto=format&fit=crop&w=2000&q=80"
      alt="Modern office team collaborating"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/65"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full flex flex-col items-start justify-center flex-grow py-20">
    <div class="max-w-4xl">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-[var(--font-body)] font-semibold tracking-tight mb-6 text-white leading-[1.15]">
        Hire dedicated remote professionals across the Pacific region
      </h1>
      
      <p class="text-lg md:text-2xl text-[#F3F4F6] mb-10 leading-relaxed max-w-3xl font-[var(--font-body)] font-normal">

---
interface Props {
  showText?: boolean;
  size?: 'sm' | 'md' | 'lg';
  theme?: 'light' | 'dark';
  class?: string;
}

const { showText = true, size = 'md', theme = 'light', class: className = '' } = Astro.props;
const waveColor = theme === 'dark' ? '#FFFFFF' : '#1B3A5C';
const textClass = theme === 'dark' ? 'text-white' : 'text-[var(--text-primary)]';

const sizes = {
  sm: { box: 'w-8 h-8', icon: 'w-8 h-8', text: 'text-base' },
  md: { box: 'w-10 h-10', icon: 'w-10 h-10', text: 'text-xl' },
  lg: { box: 'w-12 h-12', icon: 'w-12 h-12', text: 'text-2xl' },
};
const s = sizes[size];
---

<span class={`inline-flex items-center gap-2.5 ${className}`}>
  <svg
    class={`${s.icon} shrink-0`}
    viewBox="0 0 40 40"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <!-- Growth / direction (coral) -->
    <path
      d="M20 5 L31 26 H25 L20 16 L15 26 H9 L20 5 Z"
      fill="#E8593C"
    />
    <!-- Pacific wave lines (navy) -->
    <path
      d="M7 30 C11 26, 15 34, 20 30 C25 26, 29 34, 33 30"
      stroke={waveColor}
      stroke-width="2.5"
      stroke-linecap="round"
    />
    <path
      d="M5 35 C10 31, 14 38, 20 35 C26 32, 30 38, 35 35"
      stroke={waveColor}
      stroke-width="2.5"
      stroke-linecap="round"
    />
  </svg>
  {showText && (
    <span class={`font-[var(--font-body)] font-semibold tracking-tight ${textClass} ${s.text}`}>
      Pacific Ocean Tech
    </span>
  )}
</span>

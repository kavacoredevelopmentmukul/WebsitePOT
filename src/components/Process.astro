---
const steps = [
  {
    number: "01",
    title: "Tell Us Your Need",
    description: "Share your project requirements, tech stack, and ideal team size. We assign a dedicated account manager."
  },
  {
    number: "02",
    title: "We Shortlist in 48h",
    description: "Our AI-driven talent matching system finds the perfect candidates from our pre-vetted pool of 5,000+ experts."
  },
  {
    number: "03",
    title: "You Interview",
    description: "Conduct technical interviews and cultural fit assessments with our shortlisted candidates. No obligation."
  },
  {
    number: "04",
    title: "Onboard in 1 Week",
    description: "Select your team. We handle the HR, payroll, equipment, and IT security. They start working in your timezone."
  }
];
---

<section class="py-24 bg-[var(--bg-surface)] relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-5xl font-heading font-bold mb-6">How It Works</h2>
      <p class="text-lg text-[var(--text-muted)]">Scale your team rapidly with our streamlined, risk-free process.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div class="relative group">
          {/* Connecting line for desktop */}
          {index < steps.length - 1 && (
            <div class="hidden lg:block absolute top-8 left-[60%] w-full h-[2px] bg-[var(--color-accent)]/30"></div>
          )}
          
          <div class="ve-card p-8 h-full border-t-4 border-t-[var(--color-accent)]/20 group-hover:border-t-[var(--color-accent)] transition-all duration-300">
            <div class="text-5xl font-mono font-bold text-[var(--color-accent)]/20 mb-6 group-hover:text-[var(--color-accent)] transition-colors">
              {step.number}
            </div>
            <h3 class="text-xl font-heading font-bold mb-3">{step.title}</h3>
            <p class="text-sm text-[var(--text-muted)] leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

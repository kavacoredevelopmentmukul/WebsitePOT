---
import Logo from './Logo.astro';
import { Twitter, Facebook, Linkedin, Youtube, Instagram, Mail, Phone, MapPin } from 'lucide-astro';
import { allServices } from '../data/services';
import { path } from '../utils/paths';

const currentYear = new Date().getFullYear();

const companyLinks = [
  { label: 'About Us', href: path('about') },
  { label: 'Our Team', href: path('team') },
  { label: 'Contact Us', href: path('contact') },
  { label: 'Testimonials', href: path('testimonials') },
  { label: 'Case Studies', href: path('case-studies') },
  { label: 'Careers', href: path('careers') },
];

const resourceLinks = [
  { label: 'Blog & Insights', href: path('blog') },
  { label: 'How POT Works', href: path('/#how-it-works') },
  { label: 'Privacy Policy', href: path('privacy-policy') },
  { label: 'Terms of Service', href: path('terms-of-service') },
  { label: 'Cookie Policy', href: path('cookie-policy') },
  { label: 'Refund Policy', href: path('refund') },
  { label: 'Data Security', href: path('security') },
  { label: 'LLMs.txt', href: path('llms.txt') },
];
---

<footer class="bg-[var(--navy-deep)] text-[var(--cream)] pt-20 pb-10">
  <div class="pot-container">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">

      <!-- Services -->
      <div>
        <h3 class="eyebrow eyebrow-cream mb-6">Services</h3>
        <ul class="space-y-3 text-sm text-[rgba(244,239,230,0.7)] max-h-80 overflow-y-auto pr-2 body-sm">
          <li><a href={path('services')} class="hover:text-[var(--coral)] transition-colors font-medium text-[var(--cream)]">All Services</a></li>
          {allServices.map(service => (
            <li>
              <a href={path(`services/${service.id}`)} class="hover:text-[var(--coral)] transition-colors">{service.title}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="eyebrow eyebrow-cream mb-6">Company</h3>
        <ul class="space-y-3 body-sm text-[rgba(244,239,230,0.7)]">
          {companyLinks.map(link => (
            <li><a href={link.href} class="hover:text-[var(--coral)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="eyebrow eyebrow-cream mb-6">Resources</h3>
        <ul class="space-y-3 body-sm text-[rgba(244,239,230,0.7)]">
          {resourceLinks.map(link => (
            <li><a href={link.href} class="hover:text-[var(--coral)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="eyebrow eyebrow-cream mb-6">Contact</h3>
        <ul class="space-y-4 body-sm text-[rgba(244,239,230,0.7)]">
          <li class="flex items-start gap-3">
            <Mail class="w-4 h-4 shrink-0 mt-0.5 text-[#E8593C]" />
            <a href="mailto:hello@pacificoceantech.com" class="hover:text-[#E8593C] transition-colors">hello@pacificoceantech.com</a>
          </li>
          <li class="flex items-start gap-3">
            <Phone class="w-4 h-4 shrink-0 mt-0.5 text-[#E8593C]" />
            <a href="tel:+15551234567" class="hover:text-[#E8593C] transition-colors">+1 (555) 123-4567</a>
          </li>
          <li class="flex items-start gap-3">
            <MapPin class="w-4 h-4 shrink-0 mt-0.5 text-[#E8593C]" />
            <span>Tech Park Sector 17, Chandigarh 160017, India</span>
          </li>
        </ul>

        <p class="text-xs text-gray-400 mt-6 mb-3">Follow us</p>
        <div class="flex flex-wrap gap-2">
          <a href="#" class="w-10 h-10 rounded-md border border-gray-500 flex items-center justify-center text-gray-300 hover:text-white hover:border-[#E8593C] hover:bg-[#E8593C] transition-all" aria-label="Twitter">
            <Twitter class="w-4 h-4" />
          </a>
          <a href="#" class="w-10 h-10 rounded-md border border-gray-500 flex items-center justify-center text-gray-300 hover:text-white hover:border-[#E8593C] hover:bg-[#E8593C] transition-all" aria-label="Facebook">
            <Facebook class="w-4 h-4" />
          </a>
          <a href="#" class="w-10 h-10 rounded-md border border-gray-500 flex items-center justify-center text-gray-300 hover:text-white hover:border-[#E8593C] hover:bg-[#E8593C] transition-all" aria-label="LinkedIn">
            <Linkedin class="w-4 h-4" />
          </a>
          <a href="#" class="w-10 h-10 rounded-md border border-gray-500 flex items-center justify-center text-gray-300 hover:text-white hover:border-[#E8593C] hover:bg-[#E8593C] transition-all" aria-label="YouTube">
            <Youtube class="w-4 h-4" />
          </a>
          <a href="#" class="w-10 h-10 rounded-md border border-gray-500 flex items-center justify-center text-gray-300 hover:text-white hover:border-[#E8593C] hover:bg-[#E8593C] transition-all" aria-label="Instagram">
            <Instagram class="w-4 h-4" />
          </a>
        </div>

        <a href={path('/')} class="inline-block mt-8">
          <Logo size="md" theme="dark" />
        </a>
      </div>
    </div>

    <div class="pt-8 border-t border-[rgba(244,239,230,0.15)] flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="body-sm text-[rgba(244,239,230,0.5)]">
        &copy; {currentYear} Pacific Ocean Tech. All rights reserved.
      </p>
      <p class="mono-label text-[rgba(244,239,230,0.45)]">Established 2015 · 500+ professionals placed · 12+ countries served</p>
    </div>
  </div>
</footer>

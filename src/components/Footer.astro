---
import { Twitter, Facebook, Linkedin, Youtube, Instagram } from 'lucide-astro';
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#111827] text-white pt-20 pb-10">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <!-- Company -->
      <div>
        <h3 class="font-heading font-bold mb-6 text-lg tracking-wide text-white">Company</h3>
        <ul class="space-y-4 text-sm text-gray-400">
          <li><a href="/about" class="hover:text-[var(--color-accent)] transition-colors">About Us</a></li>
          <li><a href="/contact" class="hover:text-[var(--color-accent)] transition-colors">Contact Us</a></li>
          <li><a href="/team" class="hover:text-[var(--color-accent)] transition-colors">Team</a></li>
          <li><a href="/blog" class="hover:text-[var(--color-accent)] transition-colors">Blog</a></li>
        </ul>
      </div>

      <!-- Why POT -->
      <div>
        <h3 class="font-heading font-bold mb-6 text-lg tracking-wide text-white">Why POT</h3>
        <ul class="space-y-4 text-sm text-gray-400">
          <li><a href="/testimonials" class="hover:text-[var(--color-accent)] transition-colors">Testimonials</a></li>
          <li><a href="/services" class="hover:text-[var(--color-accent)] transition-colors">Our Services</a></li>
          <li><a href="/case-studies" class="hover:text-[var(--color-accent)] transition-colors">Case Studies</a></li>
          <li><a href="#" class="hover:text-[var(--color-accent)] transition-colors">How Does POT Work</a></li>
        </ul>
      </div>

      <!-- Policy -->
      <div>
        <h3 class="font-heading font-bold mb-6 text-lg tracking-wide text-white">Policy</h3>
        <ul class="space-y-4 text-sm text-gray-400">
          <li><a href="#" class="hover:text-[var(--color-accent)] transition-colors">Refund Policy</a></li>
          <li><a href="#" class="hover:text-[var(--color-accent)] transition-colors">Privacy Policy</a></li>
          <li><a href="#" class="hover:text-[var(--color-accent)] transition-colors">Terms & Conditions</a></li>
          <li><a href="#" class="hover:text-[var(--color-accent)] transition-colors">Data Security</a></li>
        </ul>
      </div>

      <!-- Discover us on social -->
      <div>
        <h3 class="font-heading font-bold mb-6 text-lg tracking-wide text-white">Discover us on social</h3>
        <div class="flex space-x-3">
          <a href="#" class="w-10 h-10 rounded-full border border-gray-700 flex items-center justify-center text-gray-400 hover:text-white hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)] transition-all">
            <span class="sr-only">Twitter</span>
            <Twitter class="w-4 h-4" />
          </a>
          <a href="#" class="w-10 h-10 rounded-full border border-gray-700 flex items-center justify-center text-gray-400 hover:text-white hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)] transition-all">
            <span class="sr-only">Facebook</span>
            <Facebook class="w-4 h-4" />
          </a>
          <a href="#" class="w-10 h-10 rounded-full border border-gray-700 flex items-center justify-center text-gray-400 hover:text-white hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)] transition-all">
            <span class="sr-only">LinkedIn</span>
            <Linkedin class="w-4 h-4" />
          </a>
          <a href="#" class="w-10 h-10 rounded-full border border-gray-700 flex items-center justify-center text-gray-400 hover:text-white hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)] transition-all">
            <span class="sr-only">YouTube</span>
            <Youtube class="w-4 h-4" />
          </a>
          <a href="#" class="w-10 h-10 rounded-full border border-gray-700 flex items-center justify-center text-gray-400 hover:text-white hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)] transition-all">
            <span class="sr-only">Instagram</span>
            <Instagram class="w-4 h-4" />
          </a>
        </div>
        
        <div class="mt-8">
          <a href="/" class="flex items-center gap-2 group">
            <div class="w-8 h-8 rounded-lg bg-[var(--color-accent)] flex items-center justify-center">
              <svg class="w-5 h-5 text-[#111827]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <span class="font-heading font-bold text-xl tracking-tight text-white">Pacific Ocean Tech</span>
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} Pacific Ocean Tech. All rights reserved.
      </p>
    </div>
  </div>
</footer>

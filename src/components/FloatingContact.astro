---
/**
 * Floating live-chat launcher via Tawk.to.
 * TODO:VERIFY-WITH-DEEPAK — Replace PROPERTY_ID and WIDGET_ID with real
 * Tawk.to credentials before launch. Sign up free at https://www.tawk.to
 */
const TAWK_PROPERTY_ID = 'PROPERTY_ID';
const TAWK_WIDGET_ID = 'default';
---

<!-- Tawk.to Live Chat Widget — non-essential, consent-gated -->
<script is:inline define:vars={{ TAWK_PROPERTY_ID, TAWK_WIDGET_ID }}>
  (function () {
    var loaded = false;

    function consentGiven() {
      // Tawk.to is a non-essential (functional) cookie. Require explicit consent.
      var c = window.potConsent;
      return !!(c && (c.functional || c.marketing));
    }

    function loadTawk() {
      // Guard: only inject once, only with a real property ID, only after consent.
      if (loaded) return;
      if (TAWK_PROPERTY_ID === 'PROPERTY_ID') return; // placeholder — never loads
      if (!consentGiven()) return;
      loaded = true;
      window.Tawk_API = window.Tawk_API || {};
      window.Tawk_LoadStart = new Date();
      var s1 = document.createElement('script');
      var s0 = document.getElementsByTagName('script')[0];
      s1.async = true;
      s1.src = 'https://embed.tawk.to/' + TAWK_PROPERTY_ID + '/' + TAWK_WIDGET_ID;
      s1.charset = 'UTF-8';
      s1.setAttribute('crossorigin', '*');
      s0.parentNode.insertBefore(s1, s0);
    }

    // Try on load (covers returning visitors who already consented)…
    loadTawk();
    // …and react the moment consent is granted.
    window.addEventListener('pot:consent-updated', loadTawk);
  })();
</script>

<!-- Fallback floating chat button (shown while PROPERTY_ID is a placeholder) -->
<div
  id="pot-chat-fallback"
  class="fixed bottom-6 right-6 z-40"
  aria-label="Live chat"
>
  <button
    type="button"
    class="flex items-center gap-2 px-4 py-3 rounded-md bg-[var(--navy)] text-white text-sm font-semibold shadow-lg hover:bg-[var(--navy-deep)] transition-colors focus:outline-none focus:ring-2 focus:ring-[var(--coral)] focus:ring-offset-2 whitespace-nowrap"
    aria-label="Open live chat"
    onclick="if(typeof Tawk_API!=='undefined'&&Tawk_API.toggle){Tawk_API.toggle()}else{window.open('mailto:hello@pacificoceantech.com','_blank')}"
  >
    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    Live Chat
  </button>
</div>

<script is:inline>
  // Hide fallback button once Tawk widget is ready
  if (typeof Tawk_API !== 'undefined') {
    Tawk_API.onLoad = function () {
      var el = document.getElementById('pot-chat-fallback');
      if (el) el.style.display = 'none';
    };
  }
</script>

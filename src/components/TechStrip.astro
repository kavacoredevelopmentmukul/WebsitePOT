---

<section class="py-12 bg-[var(--paper)] dark:bg-[var(--bg-primary)] border-t border-[var(--hairline)]" aria-label="Technologies our talent works in">
  <div class="pot-container">
    <p class="text-center text-[10px] font-bold uppercase tracking-[0.15em] text-[var(--muted)] mb-8">
      Technologies our talent works in
    </p>
    <ul class="flex flex-wrap items-center justify-center gap-12" role="list">
      {techs.map((tech) => (
        <li class="group" title={tech.name}>
          <div
            class="w-8 h-8 fill-current text-[var(--text-muted)] opacity-50 group-hover:opacity-100 transition-opacity duration-300"
            role="img"
            aria-label={`${tech.name} logo`}
            set:html={tech.svg}
          />
        </li>
      ))}
    </ul>
  </div>
</section>

---
import { path } from '../utils/paths';

interface Props {
  title: string;
  description: string;
  slug: string;
  image: string;
  subcategories: { name: string }[];
  isFeatured?: boolean;
}

const { title, description, slug, image, subcategories, isFeatured = false } = Astro.props;
---

<article class={`card group flex flex-col h-full overflow-hidden ${isFeatured ? 'md:flex-row md:col-span-2' : ''}`}>
  <div class={`relative overflow-hidden bg-[var(--cream)] ${isFeatured ? 'md:w-[42%] min-h-[14rem] md:min-h-0' : 'h-52'}`}>
    <img
      src={image}
      alt={`${title} service`}
      class="w-full h-full object-cover min-h-[13rem] transition-transform duration-500 group-hover:scale-[1.02]"
      loading="lazy"
      width="600"
      height="208"
    />
  </div>

  <div class={`flex flex-col flex-1 ${isFeatured ? 'md:w-[58%] p-8 md:p-10' : 'p-7 md:p-8'}`}>
    <h3 class="h-section text-[var(--ink)] dark:text-[var(--text-primary)] mb-3 text-[1.35rem]">
      {title}
    </h3>

    <p class="body-md mb-6 flex-grow line-clamp-4">
      {description}
    </p>

    <div class="flex flex-wrap gap-2 mb-8">
      {subcategories.slice(0, isFeatured ? 5 : 3).map((sub) => (
        <span class="mono-label px-3 py-1.5 rounded-full border border-[var(--hairline)] text-[var(--muted)] bg-[var(--paper)]">
          {sub.name}
        </span>
      ))}
      {subcategories.length > (isFeatured ? 5 : 3) && (
        <span class="mono-label px-3 py-1.5 rounded-full border border-[var(--hairline)] text-[var(--muted)]">
          +{subcategories.length - (isFeatured ? 5 : 3)} more
        </span>
      )}
    </div>

    <a
      href={path(`services/${slug}`)}
      class="mono-label text-[var(--navy)] hover:text-[var(--coral)] transition-colors inline-flex items-center gap-2 w-fit"
      aria-label={`Learn more about ${title}`}
    >
      Learn more
      <span aria-hidden="true">→</span>
    </a>
  </div>
</article>

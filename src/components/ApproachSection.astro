---
import { path } from '../utils/paths';

const steps = [
  { num: '01', title: 'Tell Us Your Need', description: 'Share your project requirements, tech stack, and ideal team size. We assign a dedicated account manager.' },
  { num: '02', title: 'We Shortlist in 48h', description: 'Our AI-driven talent matching system finds the perfect candidates from our pre-vetted pool of 5,000+ experts.' },
  { num: '03', title: 'You Interview', description: 'Conduct technical interviews and cultural fit assessments with our shortlisted candidates. No obligation.' },
  { num: '04', title: 'Onboard in 1 Week', description: 'Select your team. We handle the HR, payroll, equipment, and IT security. They start working in your timezone.' },
];
---

<section class="pot-section bg-[var(--white)] dark:bg-[var(--bg-surface)]" id="how-it-works" aria-labelledby="approach-heading">
  <div class="pot-container">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14">
      <div class="max-w-xl">
        <p class="eyebrow mb-3">How it works</p>
        <h2 id="approach-heading" class="h-section text-[var(--ink)] dark:text-[var(--text-primary)]">
          Four steps to your dedicated team
        </h2>
      </div>
      <a href={path('contact')} class="pot-btn-primary shrink-0">Start hiring</a>
    </div>

    <div class="pot-approach-grid">
      {steps.map((step) => (
        <div class="pot-approach-step">
          <span class="pot-approach-num">{step.num}</span>
          <h3>{step.title}</h3>
          <p class="body-sm">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { caseStudies } from '../data/case-studies';
import { path } from '../utils/paths';
import { breadcrumbSchema, webPageSchema } from '../utils/seo';
import { Check, ArrowRight, Quote } from 'lucide-astro';

const schemas = [
  webPageSchema('Case Studies', 'Client success stories from Pacific Ocean Tech across e-commerce, fintech, healthcare, SaaS, and more.', 'case-studies'),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Case Studies', path: 'case-studies' },
  ]),
];
---

<BaseLayout
  title="Case Studies"
  description="See how Pacific Ocean Tech clients achieved measurable growth with dedicated remote teams—revenue, uptime, denials, and time saved."
  schemas={schemas}
>
  <Header />

  <main id="main-content">
    <section class="pot-section bg-[var(--bg-surface)] pt-28">
      <div class="pot-container text-center max-w-3xl mx-auto">
        <p class="pot-eyebrow mb-3">Proof</p>
        <h1 class="pot-display text-[var(--text-primary)] mb-4">Case Studies</h1>
        <p class="text-lg text-[var(--text-muted)] leading-relaxed">
          Real outcomes from dedicated teams — industry context, challenges, solutions, and results with specific numbers.
        </p>
      </div>
    </section>

    <section class="pot-section bg-[var(--bg-primary)]">
      <div class="pot-container">
        <div class="space-y-24">
          {caseStudies.map((study, index) => (
            <article class="ve-card overflow-hidden" id={study.id}>
              <div class="h-64 md:h-80 overflow-hidden bg-[var(--bg-surface)]">
                <img src={study.image} alt={`${study.client} case study — ${study.industry}`} class="w-full h-full object-cover" loading={index === 0 ? 'eager' : 'lazy'} />
              </div>
              <div class="p-8 md:p-12">
                <div class="flex flex-wrap gap-3 mb-4">
                  <span class="text-xs font-semibold uppercase tracking-wider text-[#E8593C]">{study.industry}</span>
                  <span class="text-xs text-[var(--text-muted)]">· {study.service}</span>
                  <span class="text-xs text-[var(--text-muted)]">· {study.category}</span>
                </div>
                <h2 class="text-2xl md:text-3xl font-heading font-bold text-[var(--text-primary)] mb-8">{study.title}</h2>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
                  <div class="lg:col-span-2 space-y-8">
                    {/* Problem */}
                    <div>
                      <h3 class="text-lg font-heading font-bold text-[var(--text-primary)] mb-4 flex items-center gap-2">
                        <span class="w-8 h-8 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center text-[#E8593C] text-sm font-bold shrink-0">1</span>
                        The Problem
                      </h3>
                      <div class="space-y-3 text-[var(--text-muted)] text-sm leading-relaxed">
                        <p>{study.challenge}</p>
                        <p>{study.challengeDetail}</p>
                      </div>
                    </div>

                    {/* What We Did */}
                    <div>
                      <h3 class="text-lg font-heading font-bold text-[var(--text-primary)] mb-4 flex items-center gap-2">
                        <span class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 dark:text-blue-400 text-sm font-bold shrink-0">2</span>
                        What We Did
                      </h3>
                      <ul class="space-y-3">
                        {study.solutionBullets.map((bullet) => (
                          <li class="flex items-start gap-3 text-[var(--text-muted)] text-sm leading-relaxed">
                            <ArrowRight class="w-4 h-4 shrink-0 text-[#E8593C] mt-0.5" aria-hidden="true" />
                            <span>{bullet}</span>
                          </li>
                        ))}
                      </ul>
                    </div>

                    {/* Results */}
                    <div>
                      <h3 class="text-lg font-heading font-bold text-[var(--text-primary)] mb-4 flex items-center gap-2">
                        <span class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center text-green-600 dark:text-green-400 text-sm font-bold shrink-0">3</span>
                        Results
                      </h3>
                      <ul class="space-y-3 mb-4">
                        {study.results.map((r) => (
                          <li class="flex items-start gap-3 text-[var(--text-muted)] text-sm leading-relaxed">
                            <Check class="w-4 h-4 shrink-0 text-green-600 dark:text-green-400 mt-0.5" aria-hidden="true" />
                            <span>{r}</span>
                          </li>
                        ))}
                      </ul>
                      <p class="text-[var(--text-muted)] text-sm leading-relaxed italic">{study.resultsContext}</p>
                    </div>
                  </div>

                  {/* Sidebar: Quote + CTA */}
                  <div class="space-y-8">
                    <div class="p-6 bg-[var(--bg-surface)] rounded-lg border-l-4 border-l-[var(--color-accent)]">
                      <Quote class="w-8 h-8 text-[var(--color-accent)]/30 mb-3" aria-hidden="true" />
                      <p class="text-sm italic text-[var(--text-primary)] leading-relaxed mb-4">{study.quote}</p>
                      <div>
                        <p class="text-sm font-bold text-[var(--text-primary)]">{study.quoteAuthor}</p>
                        <p class="text-xs text-[var(--text-muted)]">{study.quoteRole}</p>
                      </div>
                    </div>

                    <div class="p-6 bg-[var(--navy-deep)] rounded-lg text-center">
                      <p class="text-sm text-[var(--cream)]/80 mb-4">Want results like these for your team?</p>
                      <a href={path('contact')} class="inline-block w-full px-6 py-3 rounded-md bg-[#E8593C] text-white font-medium text-sm hover:bg-[#cf4b31] transition-colors">
                        Talk to Us
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="text-center mt-16">
          <a href={path('contact')} class="pot-btn-primary">Start your success story</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { path } from '../utils/paths';
import { MapPin, Clock, Briefcase, ChevronDown } from 'lucide-astro';

const perks = [
  "Fully remote — work from anywhere in India",
  "Flexible schedules with guaranteed timezone overlap",
  "Competitive compensation benchmarked to top-quartile Indian market rates",
  "Monthly learning stipend for courses, books, and conferences",
  "Enterprise-grade hardware provided (MacBook Pro, monitors, peripherals)",
  "Annual team retreats and quarterly virtual summits",
  "Health insurance coverage for you and your family",
  "Dedicated career growth path with quarterly reviews",
];

const roles = [
  {
    id: "senior-fullstack",
    title: "Senior Full-Stack Engineer",
    department: "Engineering",
    location: "Remote — India",
    type: "Full-time, Dedicated Client",
    summary: "Join a client engineering team as an embedded full-stack developer, building and shipping production features across the entire stack. You'll work directly in the client's codebase, participate in their sprint ceremonies, and own features end-to-end.",
    responsibilities: [
      "Design, build, and deploy full-stack features using React/Next.js on the frontend and Node.js or Python on the backend, working within the client's existing architecture and coding standards.",
      "Participate in daily standups, sprint planning, and retrospectives as a core member of the client's engineering team — not as an external contractor.",
      "Conduct and receive code reviews with a focus on maintainability, performance, and security, raising the quality bar for the entire team.",
      "Collaborate with product managers and designers to translate requirements into technical specifications, proactively identifying edge cases and implementation trade-offs.",
      "Contribute to infrastructure and DevOps improvements including CI/CD pipelines, monitoring, and automated testing to increase deployment confidence and velocity.",
    ],
    requirements: [
      "5+ years of professional experience building production web applications with React (or Next.js) and a backend framework (Node.js, Django, or FastAPI).",
      "Strong understanding of relational databases (PostgreSQL, MySQL) and experience with ORM patterns, query optimisation, and database migrations.",
      "Proficiency with Git workflows, CI/CD tooling (GitHub Actions, GitLab CI, or similar), and containerisation (Docker).",
      "Excellent written and verbal English communication skills — you'll be participating in client standups and async discussions daily.",
      "Experience working in a remote-first environment with US, European, or Australian teams across time zones.",
    ],
  },
  {
    id: "ml-engineer",
    title: "Machine Learning Engineer",
    department: "AI/ML",
    location: "Remote — India",
    type: "Full-time, Dedicated Client",
    summary: "Work embedded within a client's AI team to design, build, and deploy production machine learning systems. You'll take models from prototype to production, build evaluation frameworks, and optimise inference pipelines for cost and latency.",
    responsibilities: [
      "Design and implement production RAG pipelines, fine-tuning workflows, and real-time inference systems using frameworks like LangChain, LlamaIndex, or custom architectures.",
      "Build comprehensive evaluation frameworks with automated test suites to measure model accuracy, latency, and regression across deployments.",
      "Optimise inference costs through model selection, quantisation, caching strategies, and tiered routing (e.g., fast model for simple queries, larger model for complex ones).",
      "Collaborate with data engineers to build and maintain data pipelines for training, embedding generation, and vector database indexing.",
      "Communicate model behaviour, limitations, and confidence metrics to product managers and non-technical stakeholders in clear, actionable terms.",
    ],
    requirements: [
      "3+ years of experience deploying ML models to production, with hands-on experience in at least two of: NLP, RAG systems, computer vision, or recommendation systems.",
      "Strong proficiency in Python and ML frameworks (PyTorch, TensorFlow, or JAX) with experience in production serving (FastAPI, TensorFlow Serving, or Triton).",
      "Experience with vector databases (Pinecone, Weaviate, Qdrant, or Chroma) and embedding models for semantic search and retrieval.",
      "Solid understanding of LLM architectures, prompt engineering, fine-tuning techniques (LoRA, QLoRA), and evaluation methodologies.",
      "Excellent English communication skills and experience working in cross-functional teams with product managers, designers, and backend engineers.",
    ],
  },
  {
    id: "senior-mobile",
    title: "Senior Mobile Developer (Flutter)",
    department: "Engineering",
    location: "Remote — India",
    type: "Full-time, Dedicated Client",
    summary: "Build and maintain cross-platform mobile applications for client products using Flutter. You'll own the mobile experience end-to-end, from architecture decisions to App Store submissions, working as a core member of the client's engineering team.",
    responsibilities: [
      "Architect and develop cross-platform mobile applications using Flutter/Dart, implementing clean architecture patterns and state management solutions (Riverpod, BLoC, or Provider).",
      "Integrate with backend APIs (REST and GraphQL), implement secure authentication flows (biometric, MFA, OAuth), and handle offline-first data synchronisation.",
      "Build and maintain CI/CD pipelines for automated testing, screenshot testing across device profiles, and staged rollouts via Firebase App Distribution or TestFlight.",
      "Optimise app performance including startup time, frame rates, memory usage, and battery consumption, targeting 99.5%+ crash-free sessions.",
      "Collaborate with the client's design team to implement pixel-perfect UIs with smooth animations and accessibility compliance (WCAG 2.1 AA).",
    ],
    requirements: [
      "4+ years of mobile development experience with at least 2 years building production Flutter applications published on both App Store and Google Play.",
      "Strong Dart fundamentals and experience with Flutter's widget lifecycle, custom rendering, platform channels, and native module integration.",
      "Experience implementing secure data handling including encrypted storage, certificate pinning, and compliance with SOC 2 or equivalent security requirements.",
      "Familiarity with mobile analytics, crash reporting (Firebase Crashlytics, Sentry), and A/B testing frameworks for mobile applications.",
      "Excellent English communication skills and ability to work independently within a remote client team across time zones.",
    ],
  },
  {
    id: "ui-ux-designer",
    title: "Senior UI/UX Designer",
    department: "Design",
    location: "Remote — India",
    type: "Full-time, Dedicated Client",
    summary: "Join client design teams as an embedded UI/UX designer, creating user interfaces for web and mobile products. You'll work within existing brand systems and design libraries, conducting user research and delivering production-ready Figma specs.",
    responsibilities: [
      "Design user interfaces for web and mobile applications within the client's existing brand system, component library, and design tokens in Figma.",
      "Conduct user research including stakeholder interviews, usability testing, and competitive analysis to inform design decisions with evidence rather than assumption.",
      "Create wireframes, high-fidelity mockups, interactive prototypes, and detailed design specifications with responsive breakpoints and interaction states.",
      "Collaborate closely with frontend engineers during implementation, conducting design QA reviews and providing redline specifications to ensure pixel-perfect delivery.",
      "Contribute to and maintain the client's design system, creating reusable components, documenting usage guidelines, and ensuring accessibility compliance (WCAG 2.1 AA).",
    ],
    requirements: [
      "5+ years of professional UI/UX design experience with a strong portfolio demonstrating work on SaaS, e-commerce, or fintech products.",
      "Expert-level Figma proficiency including auto-layout, components, variants, design tokens, and interactive prototyping.",
      "Strong understanding of responsive design, accessibility standards (WCAG 2.1), and platform-specific design patterns (iOS HIG, Material Design).",
      "Experience with user research methodologies including usability testing, A/B test analysis, and journey mapping.",
      "Excellent English communication skills and experience presenting design decisions and rationale to non-design stakeholders.",
    ],
  },
  {
    id: "devops-engineer",
    title: "DevOps / Platform Engineer",
    department: "Engineering",
    location: "Remote — India",
    type: "Full-time, Dedicated Client",
    summary: "Embed within a client's infrastructure team to build, maintain, and improve their cloud infrastructure, CI/CD pipelines, and observability stack. You'll focus on reliability, security, and developer productivity.",
    responsibilities: [
      "Design and maintain cloud infrastructure on AWS, GCP, or Azure using Infrastructure as Code (Terraform, Pulumi, or CloudFormation) with a focus on security, cost optimisation, and high availability.",
      "Build and optimise CI/CD pipelines (GitHub Actions, GitLab CI, Jenkins) to reduce build times, improve test reliability, and enable confident, frequent deployments.",
      "Implement and maintain observability stacks including logging (ELK, Datadog), metrics (Prometheus, Grafana), tracing (Jaeger, OpenTelemetry), and alerting with meaningful SLOs.",
      "Manage container orchestration using Kubernetes (EKS, GKE, or AKS), including cluster operations, Helm chart management, and auto-scaling configuration.",
      "Collaborate with development teams to improve developer experience, reduce environment setup friction, and implement security best practices including secrets management and network segmentation.",
    ],
    requirements: [
      "4+ years of DevOps or platform engineering experience in a production environment running containerised workloads at scale.",
      "Strong proficiency with at least one major cloud provider (AWS preferred) including networking (VPC, security groups), compute (ECS, EKS, Lambda), and storage services.",
      "Hands-on experience with Terraform or Pulumi for infrastructure management, and Kubernetes for container orchestration.",
      "Experience implementing security controls including IAM policies, secrets management (Vault, AWS Secrets Manager), and network segmentation for compliance requirements (SOC 2, HIPAA, or GDPR).",
      "Excellent English communication skills and experience supporting distributed engineering teams across multiple time zones.",
    ],
  },
];
---

<BaseLayout
  title="Careers"
  description="Join Pacific Ocean Tech and work with the world's most innovative companies. Browse open roles and apply today."
>
  <Header />

  <main id="main-content">
    <!-- Hero -->
    <section class="pot-section pt-32 bg-[var(--bg-surface)]">
      <div class="pot-container text-center">
        <p class="eyebrow mb-3">Careers</p>
        <h1 class="h-section text-[var(--text-primary)] mb-4">Build Your Career With Global Impact</h1>
        <p class="lede max-w-3xl mx-auto">
          Join the top 3% of engineers who power the world's fastest-growing companies. Work remotely, grow continuously, and solve problems that matter.
        </p>
      </div>
    </section>

    <!-- Why Work With Us -->
    <section class="py-24">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-[var(--text-primary)]">Why Work With Us</h2>
          <p class="mt-4 text-lg text-[var(--text-muted)] max-w-2xl mx-auto">We invest in our people because they are our product. Here's what you get when you join the POT talent network.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          {perks.map(perk => (
            <div class="ve-card p-6 text-center">
              <p class="text-sm text-[var(--text-muted)] leading-relaxed">{perk}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Open Roles -->
    <section class="py-24 bg-[var(--bg-surface)]">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="eyebrow mb-3">Open positions</p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-[var(--text-primary)]">Current Openings</h2>
          <p class="mt-4 text-lg text-[var(--text-muted)] max-w-2xl mx-auto">We're hiring across engineering, design, and AI. Every role is fully remote and involves dedicated, long-term work with a single client.</p>
        </div>

        <div class="space-y-6 max-w-4xl mx-auto">
          {roles.map(role => (
            <details class="ve-card overflow-hidden group" id={role.id}>
              <summary class="p-6 md:p-8 cursor-pointer list-none flex items-center justify-between gap-4 hover:bg-[var(--bg-surface)] transition-colors">
                <div>
                  <h3 class="text-xl font-heading font-bold text-[var(--text-primary)] mb-2">{role.title}</h3>
                  <div class="flex flex-wrap gap-3 text-xs text-[var(--text-muted)]">
                    <span class="flex items-center gap-1"><Briefcase class="w-3 h-3" aria-hidden="true" />{role.department}</span>
                    <span class="flex items-center gap-1"><MapPin class="w-3 h-3" aria-hidden="true" />{role.location}</span>
                    <span class="flex items-center gap-1"><Clock class="w-3 h-3" aria-hidden="true" />{role.type}</span>
                  </div>
                </div>
                <ChevronDown class="w-5 h-5 text-[var(--text-muted)] transition-transform group-open:rotate-180 shrink-0" aria-hidden="true" />
              </summary>

              <div class="px-6 md:px-8 pb-8 border-t border-[var(--hairline)]">
                <p class="text-[var(--text-muted)] text-sm leading-relaxed mt-6 mb-6">{role.summary}</p>

                <h4 class="text-sm font-heading font-bold text-[var(--text-primary)] uppercase tracking-wider mb-3">Responsibilities</h4>
                <ul class="space-y-2 mb-6">
                  {role.responsibilities.map(r => (
                    <li class="text-sm text-[var(--text-muted)] leading-relaxed pl-4 border-l-2 border-[var(--color-accent)]/30">{r}</li>
                  ))}
                </ul>

                <h4 class="text-sm font-heading font-bold text-[var(--text-primary)] uppercase tracking-wider mb-3">Requirements</h4>
                <ul class="space-y-2 mb-6">
                  {role.requirements.map(r => (
                    <li class="text-sm text-[var(--text-muted)] leading-relaxed pl-4 border-l-2 border-blue-500/30">{r}</li>
                  ))}
                </ul>

                <h4 class="text-sm font-heading font-bold text-[var(--text-primary)] uppercase tracking-wider mb-3">Perks</h4>
                <div class="flex flex-wrap gap-2 mb-8">
                  {perks.slice(0, 5).map(p => (
                    <span class="text-[10px] font-medium px-2.5 py-1 rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)]">{p}</span>
                  ))}
                </div>

                <a href={path('contact')} class="inline-block px-8 py-3 rounded-md bg-[#E8593C] text-white font-medium text-sm hover:bg-[#cf4b31] transition-colors">
                  Apply for This Role
                </a>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 bg-[var(--navy-deep)]">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-[var(--cream)] mb-4">Don't See Your Role?</h2>
        <p class="text-lg text-[var(--cream)]/70 max-w-2xl mx-auto mb-8">We're always looking for exceptional engineers, designers, and specialists. Send us your profile and we'll reach out when a matching opportunity opens.</p>
        <a href={path('contact')} class="px-8 py-4 rounded-md bg-[#E8593C] text-white font-medium hover:bg-[#cf4b31] transition-colors">Get in Touch</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { team } from '../data/team';
import { User } from 'lucide-astro';
---

<BaseLayout 
  title="Our Team" 
  description="Meet the leadership and engineering experts behind Pacific Ocean Tech."
>
  <Header />
  
  <main class="pt-24 pb-16">
    <!-- Hero -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 text-center mb-24">
      <h1 class="text-4xl md:text-6xl font-heading font-extrabold mb-6 text-[var(--text-primary)]">The Minds Behind the Code</h1>
      <p class="text-xl text-[var(--text-muted)] max-w-3xl mx-auto">
        Our leadership team is composed of seasoned engineering veterans and operations experts dedicated to building the future of remote work.
      </p>
    </section>

    <!-- Team Grid -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 mb-32">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {team.map(member => (
          <div class="ve-card overflow-hidden group">
            <div class="aspect-[4/3] bg-[var(--bg-surface)] relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-[var(--bg-surface)] to-[var(--bg-primary)] flex items-center justify-center">
                 <User size={64} class="text-[var(--text-muted)]/10" />
              </div>
              <div class="absolute top-4 right-4 px-3 py-1 bg-[var(--bg-primary)]/80 backdrop-blur-md rounded-full text-xs font-medium text-[var(--text-muted)] border border-gray-200 dark:border-gray-700">
                {member.department}
              </div>
            </div>
            <div class="p-6">
              <div class="flex justify-between items-start mb-2">
                <div>
                  <h3 class="text-xl font-heading font-bold text-[var(--text-primary)]">{member.name}</h3>
                  <p class="text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)] text-sm font-medium">{member.role}</p>
                </div>
                <a href={member.linkedin} class="text-[var(--text-muted)] hover:text-[#0077b5] transition-colors" aria-label={`LinkedIn profile for ${member.name}`}>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
              </div>
              <p class="text-[var(--text-muted)] text-sm leading-relaxed mt-4">
                {member.bio}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Join Us CTA -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="ve-card p-12 md:p-16 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-8 bg-[var(--bg-surface)]">
        <div class="md:max-w-2xl text-center md:text-left">
          <h2 class="text-3xl font-heading font-bold mb-4 text-[var(--text-primary)]">Join our talent network</h2>
          <p class="text-[var(--text-muted)] text-lg">Are you a top 1% engineer looking to work with fast-growing global startups? We are always hiring.</p>
        </div>
        <a href="/careers" class="px-8 py-4 rounded-full bg-[var(--color-accent)] text-white font-bold hover:bg-[var(--color-accent-glow)] transition-colors shrink-0">
          View Open Roles
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

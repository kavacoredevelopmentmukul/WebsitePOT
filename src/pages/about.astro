---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { companyStats } from '../data/company-stats';
import { path } from '../utils/paths';
import { Star, Eye, Zap, Users, Lightbulb, ShieldCheck, Gauge, Award, BadgeDollarSign, ShieldHalf, Search, FileCheck, UserCheck, Video, Handshake } from 'lucide-astro';

const timeline = [
  { year: String(companyStats.establishedYear), title: "Founded, remote-first", desc: "Started as a small distributed engineering team." },
  { year: "2018", title: "Global client base", desc: "Expanded to serve clients across multiple continents." },
  { year: "2020", title: "Fully remote model", desc: "Formalized distributed delivery and global sourcing." },
  { year: "2023", title: "AI practice launched", desc: "Dedicated AI/ML pod for GenAI demand." },
  { year: "2025", title: `${companyStats.professionalsPlaced} placed`, desc: `Crossed ${companyStats.professionalsPlaced} professionals placed across ${companyStats.countriesServed} countries.` },
];

const values = [
  { Icon: Star, title: "Excellence", desc: "We hire only the top 3% of applicants and enforce rigorous engineering standards. Every engineer in our network has passed a multi-stage technical screening that evaluates not just coding ability, but architectural thinking and communication skills. We conduct quarterly code-quality audits and pair lower-performing team members with senior mentors to keep output consistently high. For our clients, this means fewer defects, faster onboarding, and production-ready code from day one." },
  { Icon: Eye, title: "Transparency", desc: "No hidden fees, no black-box processes. Complete visibility into your team. We provide real-time dashboards showing hours logged, sprint velocity, and pull-request throughput so you always know exactly where your investment is going. Our pricing is published and line-itemized — you see the engineer's compensation, our management fee, and nothing else. When problems arise, we surface them early rather than burying them in status reports." },
  { Icon: Zap, title: "Speed", desc: "Time is the ultimate competitive advantage. We move fast without breaking things. Our pre-vetted talent bench means we can present qualified candidates within 48 hours, not weeks. We run parallel interview loops so you can evaluate multiple engineers simultaneously, and our onboarding playbook gets new hires contributing to your codebase within their first week. When a role needs to be backfilled, we activate a replacement within 72 hours to minimize disruption." },
  { Icon: Users, title: "Partnership", desc: "We don't want to be a vendor. We want to be an extension of your company. Every client is assigned a dedicated Client Success Manager who understands your tech stack, your sprint cadence, and your long-term roadmap. We participate in your standups, retros, and planning sessions — not as observers, but as contributors. Our retention rate of " + companyStats.clientRetention + " proves this model works: clients stay because we become indispensable, not because of lock-in." },
  { Icon: Lightbulb, title: "Innovation", desc: "Always adopting the latest technologies, from Next.js to enterprise RAG pipelines. We invest heavily in continuous education, giving every engineer a monthly learning stipend and dedicated time for upskilling. Our internal tech radar tracks emerging frameworks and tools so we can proactively advise clients on migration paths. We've helped multiple clients adopt AI-assisted development workflows that boosted their team velocity by 30% or more." },
  { Icon: ShieldCheck, title: "Integrity", desc: "We protect your IP, respect your data, and always deliver on our promises. Every engineer signs an NDA and an IP assignment agreement before they touch your codebase. We enforce endpoint security policies including encrypted drives, VPN-only access, and monitored development environments. If we can't meet a commitment, we tell you before the deadline — not after. Trust is earned slowly and lost instantly, and we build our entire operation around that principle." },
];

const differentiators = [
  { Icon: Gauge, title: "Speed", headline: "48-Hour Candidate Delivery", desc: "While traditional agencies take 4–6 weeks to present candidates, our pre-vetted bench means you interview qualified engineers within 48 hours. We run parallel pipelines, so you evaluate three to five candidates simultaneously instead of waiting for a single shortlist." },
  { Icon: Award, title: "Quality", headline: "~3% Vetting Pass Rate", desc: "Only 3 out of every 100 applicants make it through our five-stage vetting process. We test live coding, system design, communication, and cultural fit. The result is engineers who don't just write code — they own outcomes and think like product builders." },
  { Icon: BadgeDollarSign, title: "Cost", headline: companyStats.costSavings + " Savings", desc: "Transparent, line-itemized pricing with up to 70% savings versus local hiring — without compromising quality. You see the engineer’s compensation, our management fee, and nothing else." },
  { Icon: ShieldHalf, title: "Compliance", headline: "Enterprise-Grade Security", desc: "Every engagement includes signed NDAs, IP assignment agreements, GDPR-compliant data handling, and SOC 2-aligned operational controls. We enforce endpoint security, VPN-only access to client repositories, and quarterly security audits. Your code and data stay protected." },
];

const hiringSteps = [
  { step: 1, Icon: Search, title: "Sourcing & Screening", desc: "We source candidates from top engineering institutions, developer communities, and our referral network across our global network. Every applicant completes an automated screening that evaluates years of experience, tech-stack alignment, and English communication. Only the top 20% advance." },
  { step: 2, Icon: FileCheck, title: "Technical Assessment", desc: "Candidates complete a timed coding challenge designed by our principal engineers. We evaluate algorithmic thinking, code quality, edge-case handling, and test coverage. Assessments are language-specific and calibrated to real-world scenarios, not LeetCode puzzles." },
  { step: 3, Icon: UserCheck, title: "System Design & Architecture", desc: "Senior candidates face a live system-design interview where they architect a distributed system end-to-end. We evaluate trade-off reasoning, scalability thinking, and the ability to communicate decisions clearly — the skills that separate a coder from an engineer." },
  { step: 4, Icon: Video, title: "Communication & Culture Fit", desc: "A 45-minute behavioral interview assesses collaboration style, timezone flexibility, and alignment with remote-first work culture. We simulate real client interactions — standup updates, code-review discussions, and async Slack communication — to ensure a seamless fit." },
  { step: 5, Icon: Handshake, title: "Client Match & Onboarding", desc: "We present a curated shortlist with detailed profiles, portfolio samples, and assessment scores. Once you select your engineer, our onboarding playbook handles environment setup, access provisioning, and a structured first-week ramp plan so they're contributing from day one." },
];

const aboutStats = [
  { value: `${new Date().getFullYear() - companyStats.establishedYear}+`, label: "Years in Business" },
  { value: companyStats.countriesServed, label: "Countries Served" },
  { value: companyStats.clientRetention, label: "Client Retention" },
  { value: "3%", label: "Vetting Pass Rate" },
];
---

<BaseLayout
  title="About Us"
  description="Learn about Pacific Ocean Tech's mission to connect ambitious teams with top-tier remote professionals across the Pacific region and beyond."
>
  <Header />

  <main id="main-content">
    <!-- Hero -->
    <section class="pot-section pt-32 bg-[var(--bg-surface)]">
      <div class="pot-container text-center">
        <p class="eyebrow mb-3">About us</p>
        <h1 class="h-section text-[var(--text-primary)] mb-4">Democratizing Access to Elite Engineering</h1>
        <p class="lede max-w-3xl mx-auto">
          We believe a company's potential shouldn't be limited by its zip code. We connect ambitious teams with top-tier remote professionals across the Pacific region and beyond.
        </p>
      </div>
    </section>

    <!-- About Stats Band -->
    <section class="py-12 bg-[var(--navy-deep)]">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {aboutStats.map(stat => (
            <div>
              <p class="text-3xl md:text-4xl font-heading font-bold text-[var(--cream)] mb-1">{stat.value}</p>
              <p class="text-sm text-[var(--cream)]/70">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Story & Vision -->
    <section class="py-24">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6 text-[var(--text-primary)]">Our Story</h2>
            <div class="space-y-4 text-[var(--text-muted)] leading-relaxed text-lg">
              <p>
                Pacific Ocean Tech started in {companyStats.establishedYear} with a simple observation: the best companies were being throttled not by ambition or budget, but by access to talent. Hiring senior engineers in major hubs had become slow, expensive, and brutally competitive — while exceptional professionals across the wider Pacific region and global remote workforce were ready to do world-class work, if only someone would connect the two sides properly.
              </p>
              <p>
                The traditional outsourcing model wasn't the answer. It treated people as interchangeable, billed by headcount instead of outcomes, and rotated talent between clients — producing inconsistent quality and constant context-switching. We built Pacific Ocean Tech to do the opposite: place dedicated, full-time professionals who embed into a single client's team for the long term.
              </p>
              <p>
                They attend your standups, join your retros, and ship to your repositories. The only difference from an in-house hire is geography.
              </p>
              <p>
                What began as a small distributed team is now a trusted partner for {companyStats.clientsServed} companies across {companyStats.countriesServed} countries, with a {companyStats.clientRetention} retention rate. Growth has been almost entirely word-of-mouth — because the model delivers what the old way couldn't.
              </p>
            </div>

            <div class="mt-10 p-8 ve-card border-l-4 border-l-[var(--color-accent)]">
              <p class="text-lg italic text-[var(--text-primary)] font-heading mb-4">
                "Our goal is a world where building a world-class team takes days, not months — wherever your headquarters happens to be."
              </p>
              <p class="text-sm font-bold text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)]">— Daniel Hayes, Founder &amp; CEO</p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-6">
            <div class="aspect-[3/4] rounded-lg overflow-hidden bg-[var(--bg-surface)] row-span-2">
              <img
                src={path('images/about-story-1.webp')}
                alt="Pacific Ocean Tech team collaborating in a meeting"
                class="w-full h-full object-cover"
                loading="lazy"
                width="400"
                height="533"
              />
            </div>
            <div class="aspect-square rounded-lg overflow-hidden bg-[var(--bg-surface)]">
              <img
                src={path('images/about-story-2.webp')}
                alt="Remote professional working on a laptop"
                class="w-full h-full object-cover"
                loading="lazy"
                width="400"
                height="400"
              />
            </div>
            <div class="aspect-square rounded-lg overflow-hidden bg-[var(--bg-surface)]">
              <img
                src={path('images/about-story-3.webp')}
                alt="Modern corporate office building"
                class="w-full h-full object-cover"
                loading="lazy"
                width="400"
                height="400"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why We're Different -->
    <section class="py-24 bg-[var(--bg-surface)]">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="eyebrow mb-3">What sets us apart</p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-[var(--text-primary)]">Why We're Different</h2>
          <p class="mt-4 text-lg text-[var(--text-muted)] max-w-2xl mx-auto">Four pillars that separate Pacific Ocean Tech from traditional outsourcing vendors and staffing agencies.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {differentiators.map(d => (
            <div class="ve-card p-8">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 rounded-xl bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)] shrink-0">
                  <d.Icon size={24} />
                </div>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)]">{d.title}</p>
                  <h3 class="text-xl font-heading font-bold text-[var(--text-primary)]">{d.headline}</h3>
                </div>
              </div>
              <p class="text-[var(--text-muted)] text-sm leading-relaxed">{d.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Core Values -->
    <section class="py-24">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="eyebrow mb-3">What we stand for</p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-[var(--text-primary)]">Our Core Values</h2>
          <p class="mt-4 text-lg text-[var(--text-muted)] max-w-2xl mx-auto">These aren't poster slogans — they're the operating principles that shape every hire we make, every team we build, and every client relationship we nurture.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {values.map(value => (
            <div class="ve-card p-8">
              <div class="w-14 h-14 rounded-2xl bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)] mb-6">
                <value.Icon size={28} />
              </div>
              <h3 class="text-xl font-heading font-bold mb-3 text-[var(--text-primary)]">{value.title}</h3>
              <p class="text-[var(--text-muted)] text-sm leading-relaxed">{value.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How We Hire -->
    <section class="py-24 bg-[var(--bg-surface)]">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="eyebrow mb-3">Our vetting process</p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-[var(--text-primary)]">How We Hire</h2>
          <p class="mt-4 text-lg text-[var(--text-muted)] max-w-2xl mx-auto">Only 3 out of every 100 applicants make it through our five-stage vetting pipeline. Here's what each stage looks like.</p>
        </div>
        <div class="max-w-4xl mx-auto space-y-6">
          {hiringSteps.map(step => (
            <div class="ve-card p-8 flex gap-6 items-start">
              <div class="shrink-0 w-14 h-14 rounded-2xl bg-[var(--color-accent)]/10 flex items-center justify-center">
                <step.Icon size={24} class="text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)]" />
              </div>
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-mono font-bold text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)]">STEP {step.step}</span>
                  <h3 class="text-lg font-heading font-bold text-[var(--text-primary)]">{step.title}</h3>
                </div>
                <p class="text-[var(--text-muted)] text-sm leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="py-24">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-center mb-16 text-[var(--text-primary)]">Our Journey</h2>
        <div class="max-w-3xl mx-auto">
          {timeline.map((item, index) => (
            <div class="relative pl-8 sm:pl-32 py-6 group">
              <div class="absolute left-4 sm:left-[7.5rem] top-0 bottom-0 w-px bg-gray-200 dark:bg-gray-700 group-first:top-10 group-last:bottom-10"></div>
              <div class="absolute left-[calc(1rem-4px)] sm:left-[calc(7.5rem-4px)] top-8 w-3 h-3 rounded-full bg-[var(--color-accent)] ring-4 ring-[var(--bg-primary)]"></div>
              <div class="hidden sm:block absolute left-0 top-6 w-24 text-right font-mono font-bold text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)]">
                {item.year}
              </div>
              <div class="ve-card p-6 ml-4">
                <div class="sm:hidden font-mono font-bold text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)] mb-2">
                  {item.year}
                </div>
                <h3 class="text-xl font-heading font-bold mb-2 text-[var(--text-primary)]">{item.title}</h3>
                <p class="text-[var(--text-muted)] text-sm">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 bg-[var(--navy-deep)]">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-[var(--cream)] mb-4">Ready to Build Your Team?</h2>
        <p class="text-lg text-[var(--cream)]/70 max-w-2xl mx-auto mb-8">Join {companyStats.clientsServed} companies who trust Pacific Ocean Tech to scale their engineering capacity. Your first candidate profile arrives within 48 hours.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={path('contact')} class="px-8 py-4 rounded-md bg-[#E8593C] text-white font-medium hover:bg-[#cf4b31] transition-colors">Get Started Today</a>
          <a href={path('case-studies')} class="px-8 py-4 rounded-md border border-[var(--cream)]/30 text-[var(--cream)] font-medium hover:bg-[var(--cream)]/10 transition-colors">View Case Studies</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

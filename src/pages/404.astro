---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { path } from '../utils/paths';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <Header />

  <main id="main-content" class="pt-32 pb-24">
    <div class="pot-container text-center max-w-2xl mx-auto">
      <p class="text-8xl font-heading font-extrabold text-[var(--color-accent)] mb-6">404</p>
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-[var(--text-primary)] mb-4">Page not found</h1>
      <p class="text-lg text-[var(--text-muted)] mb-10">
        The page you're looking for doesn't exist or has been moved. Let's get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={path('/')} class="btn btn-primary">Back to Home</a>
        <a href={path('contact')} class="btn btn-ghost">Contact Us</a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { servicePillars } from '../../data/services';
import { path } from '../../utils/paths';
import { ArrowRight } from 'lucide-astro';
---

<BaseLayout
  title="Our Services"
  description="Explore 75+ services across Technology, Business Support, and Marketing. Hire dedicated remote professionals for any role."
>
  <Header />

  <main id="main-content" class="pt-24 pb-16">
    <!-- Hero -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 text-center mb-24">
      <h1 class="text-4xl md:text-6xl font-heading font-extrabold mb-6 text-[var(--text-primary)]">Our Services</h1>
      <p class="text-xl text-[var(--text-muted)] max-w-3xl mx-auto">
        Explore services across technology, business support, digital marketing, design, and content. Find the right talent for every role.
      </p>
    </section>

    <!-- Pillars -->
    {servicePillars.map((pillar, pillarIdx) => (
      <section class={`py-24 ${pillarIdx % 2 === 0 ? 'bg-[var(--bg-primary)]' : 'bg-[var(--bg-surface)]'}`}>
        <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
          <div class="mb-16">
            <h2 class="text-3xl md:text-5xl font-heading font-bold text-[var(--text-primary)] mb-4">{pillar.title}</h2>
            <p class="text-lg text-[var(--text-muted)] max-w-2xl">{pillar.description}</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {pillar.categories.map(cat => (
              <a href={path(`services/${cat.id}`)} class="ve-card flex flex-col h-full group overflow-hidden">
                <div class="h-40 overflow-hidden bg-[var(--bg-surface)]">
                  <img src={cat.image} alt={`${cat.title} services at Pacific Ocean Tech`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="450" height="160" />
                </div>
                <div class="p-8 flex flex-col flex-grow">
                <div class="w-14 h-14 rounded-md bg-[var(--bg-surface)] flex items-center justify-center mb-6 text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)] group-hover:bg-[var(--color-accent)] group-hover:text-white transition-all -mt-12 border-4 border-[var(--bg-primary)] relative z-10">
                  <cat.icon class="w-7 h-7" />
                </div>

                <h3 class="text-xl font-heading font-bold mb-3 text-[var(--text-primary)] group-hover:text-[var(--color-accent-secondary)] dark:group-hover:text-[var(--color-accent)] transition-colors">
                  {cat.title}
                </h3>

                <p class="text-[var(--text-muted)] text-sm mb-6 flex-grow leading-relaxed">
                  {cat.description}
                </p>

                <div class="flex flex-wrap gap-2 mb-6">
                  {cat.subcategories.slice(0, 3).map(sub => (
                    <span class="px-2.5 py-1 rounded-full text-xs font-medium border border-[var(--text-muted)]/15 text-[var(--text-muted)] bg-[var(--bg-surface)]">
                      {sub.name}
                    </span>
                  ))}
                  {cat.subcategories.length > 3 && (
                    <span class="px-2.5 py-1 rounded-full text-xs font-medium border border-[var(--text-muted)]/15 text-[var(--text-muted)] bg-[var(--bg-surface)]">
                      +{cat.subcategories.length - 3} more
                    </span>
                  )}
                </div>

                <span class="inline-flex items-center text-sm font-bold text-[var(--text-primary)] group-hover:text-[var(--color-accent-secondary)] dark:group-hover:text-[var(--color-accent)] transition-colors">
                  Learn more
                  <ArrowRight class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" />
                </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}

    <!-- CTA -->
    <section class="py-32 bg-[var(--bg-primary)]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl md:text-5xl font-heading font-bold mb-6 text-[var(--text-primary)]">Need Help Managing Daily Business Tasks?</h2>
        <a href={path('contact')} class="inline-flex px-10 py-4 rounded-full bg-[var(--color-accent)] text-white font-bold text-lg hover:bg-[var(--color-accent-glow)] transition-colors">
          Get Started
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FAQ from '../../components/FAQ.tsx';
import { servicePillars, allServices } from '../../data/services';
import { SERVICE_SLUGS } from '../../data/service-slugs';
import { serviceDetails } from '../../data/service-details';
import { path } from '../../utils/paths';
import { breadcrumbSchema, serviceSchema, faqSchema, webPageSchema } from '../../utils/seo';
import { Check } from 'lucide-astro';

export function getStaticPaths() {
  return SERVICE_SLUGS.map((slug) => {
    const service = allServices.find((s) => s.id === slug);
    const detail = serviceDetails[slug];
    if (!service || !detail) {
      throw new Error(`Missing service or detail for slug: ${slug}`);
    }
    return { params: { slug }, props: { service, detail } };
  });
}

const { service, detail } = Astro.props;
const parentPillar = servicePillars.find((p) => p.categories.some((c) => c.id === service.id));
const shortDescription = detail.tagline.split('. ').slice(0, 2).join('. ') + (detail.tagline.includes('.') ? '.' : '');

const schemas = [
  webPageSchema(`${service.title} Services`, detail.tagline, `services/${service.id}`),
  serviceSchema(service.title, detail.tagline, `services/${service.id}`),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Services', path: 'services' },
    { name: service.title, path: `services/${service.id}` },
  ]),
  faqSchema(detail.faqs),
];
---

<BaseLayout
  title={`Hire ${detail.roleName}s`}
  description={detail.tagline}
  schemas={schemas}
>
  <Header />

  <main id="main-content">
    <!-- Hero -->
    <section class="pot-section bg-[var(--bg-surface)] pt-28 pb-16 md:pb-20">
      <div class="pot-container">
        <nav class="flex flex-wrap items-center gap-2 text-sm text-[var(--text-muted)] mb-8" aria-label="Breadcrumb">
          <a href={path('/')} class="hover:text-[var(--pot-coral)] transition-colors">Home</a>
          <span>/</span>
          <a href={path('services')} class="hover:text-[var(--pot-coral)] transition-colors">Services</a>
          {parentPillar && (
            <>
              <span>/</span>
              <span class="text-[var(--text-muted)]">{parentPillar.title}</span>
            </>
          )}
          <span>/</span>
          <span class="text-[var(--text-primary)] font-medium">{service.title}</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div>
            <p class="pot-eyebrow mb-4">{service.title}</p>
            <h1 class="pot-display mb-5 text-[var(--text-primary)]">{service.title}</h1>
            <p class="text-lg md:text-xl text-[var(--text-muted)] mb-6 leading-relaxed max-w-xl">
              {shortDescription}
            </p>
            <p class="text-2xl md:text-3xl font-semibold text-[var(--navy)] dark:text-white mb-8">
              Hire {detail.roleName} from <span class="text-[#E8593C]">${detail.hourlyFrom}/hour</span>
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href={path('contact')}
                class="pot-btn-primary"
              >
                Hire a {detail.roleName} Today
              </a>
              <a href={path('services')} class="pot-btn-outline">
                View All Services
              </a>
            </div>
          </div>
          <div class="overflow-hidden rounded-md border border-black/5 dark:border-white/10">
            <img
              src={service.image}
              alt={service.title}
              class="w-full aspect-[4/3] object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Key skills -->
    <section class="pot-section bg-[var(--bg-primary)]">
      <div class="pot-container">
        <div class="max-w-3xl mb-10">
          <p class="pot-eyebrow mb-3">Capabilities</p>
          <h2 class="pot-heading-2 text-[var(--text-primary)]">Key skills covered</h2>
          <p class="text-[var(--text-muted)] mt-3 leading-relaxed">
            Every {detail.roleName.toLowerCase()} is vetted on the tools and workflows your team uses daily.
          </p>
        </div>
        <ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
          {detail.skills.map((skill) => (
            <li class="flex items-center gap-2 rounded-md border border-black/5 dark:border-white/10 bg-[var(--bg-surface)] px-4 py-3 text-sm font-medium text-[var(--text-primary)]">
              <Check class="w-4 h-4 shrink-0 text-[#E8593C]" />
              {skill}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Pull quote -->
    <section class="pot-pull-quote">
      <div class="pot-container">
        <blockquote class="pot-pull-quote-text">
          "{detail.pullQuote}"
        </blockquote>
      </div>
    </section>

    <!-- Responsibilities -->
    <section class="pot-section bg-[var(--bg-surface)]">
      <div class="pot-container">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
          <div class="lg:col-span-4">
            <p class="pot-eyebrow mb-3">Scope</p>
            <h2 class="pot-heading-2 text-[var(--text-primary)]">
              What your {detail.roleName} will do
            </h2>
          </div>
          <ul class="lg:col-span-8 space-y-4">
            {detail.responsibilities.map((item) => (
              <li class="flex gap-4 rounded-md border border-black/5 dark:border-white/10 bg-[var(--bg-primary)] p-5">
                <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-[var(--navy)] text-xs font-bold text-white">✓</span>
                <span class="text-[var(--text-muted)] leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- 4-step process -->
    <section class="pot-section bg-[var(--bg-primary)]" id="how-it-works">
      <div class="pot-container">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <p class="pot-eyebrow mb-3">Process</p>
          <h2 class="pot-heading-2 text-[var(--text-primary)]">4-step hiring process</h2>
        </div>
        <div class="pot-pillar-ledger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {detail.processSteps.map((step, index) => (
            <article class="pot-ledger-card">
              <span class="pot-ledger-num">{index + 1}</span>
              <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-2">{step.title}</h3>
              <p class="text-sm text-[var(--text-muted)] leading-relaxed">{step.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="pot-section bg-[var(--bg-surface)]">
      <div class="pot-container">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <p class="pot-eyebrow mb-3">Engagement</p>
          <h2 class="pot-heading-2 text-[var(--text-primary)]">Pricing</h2>
          <p class="text-[var(--text-muted)] mt-3">Transparent rates. No recruitment fees. Scale up or down with two weeks notice.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          {[detail.pricing.partTime, detail.pricing.fullTime].map((tier) => (
            <div class="rounded-md border-2 border-[var(--navy)]/15 bg-[var(--bg-primary)] p-8 md:p-10 flex flex-col">
              <h3 class="text-xl font-semibold text-[var(--navy)] dark:text-white mb-1">{tier.label}</h3>
              <p class="text-3xl font-bold text-[#E8593C] mb-1">{tier.price}</p>
              <p class="text-sm text-[var(--text-muted)] mb-6">{tier.subtitle}</p>
              <ul class="space-y-3 flex-grow">
                {tier.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm text-[var(--text-muted)]">
                    <Check class="w-4 h-4 shrink-0 text-[#E8593C] mt-0.5" />
                    {feature}
                  </li>
                ))}
              </ul>
              <a href={path('contact')} class="pot-btn-primary mt-8 text-center">
                Get a quote
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="pot-section bg-[var(--bg-primary)]">
      <div class="pot-container">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <p class="pot-eyebrow mb-3">FAQ</p>
          <h2 class="pot-heading-2 text-[var(--text-primary)]">Common questions</h2>
        </div>
        <FAQ client:visible items={detail.faqs} />
      </div>
    </section>

    <!-- CTA -->
    <section class="pot-cta-navy text-center">
      <div class="pot-container text-center">
        <h2 class="text-3xl md:text-4xl font-semibold text-white mb-4">
          Hire a {detail.roleName} Today
        </h2>
        <p class="text-lg text-gray-300 mb-8 max-w-xl mx-auto">
          Tell us what you need. Pre-vetted {detail.roleName.toLowerCase()}s can be on your team within 1–2 weeks.
        </p>
        <a href={path('contact')} class="inline-flex px-8 py-4 rounded-md bg-[#E8593C] text-white font-semibold text-lg hover:bg-[#cf4b31] transition-colors">
          Hire a {detail.roleName} Today
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

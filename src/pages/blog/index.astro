---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPost = sortedPosts[0];
const remainingPosts = sortedPosts.slice(1);
---

<BaseLayout 
  title="Blog & Insights" 
  description="Thoughts on AI, remote work, engineering leadership, and scaling global tech teams."
>
  <Header />
  
  <main class="pt-24 pb-16">
    <!-- Hero -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
      <h1 class="text-4xl md:text-6xl font-heading font-extrabold mb-6 text-[var(--text-primary)]">Insights & Engineering</h1>
      <p class="text-xl text-[var(--text-muted)] max-w-3xl mx-auto">
        Deep dives into AI deployment, global talent strategies, and modern software architecture.
      </p>
    </section>

    <!-- Featured Post -->
    {featuredPost && (
      <section class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 mb-24">
        <a href={`/blog/${featuredPost.id}`} class="block ve-card group overflow-hidden">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
            <div class="aspect-video lg:aspect-auto bg-[var(--bg-surface)] relative overflow-hidden">
              <img src={featuredPost.data.image} alt={featuredPost.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-8 md:p-12 flex flex-col justify-center">
              <div class="flex items-center gap-4 mb-6">
                <span class="px-3 py-1 rounded-full bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20 text-xs font-medium text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)]">
                  {featuredPost.data.category}
                </span>
                <span class="text-sm text-[var(--text-muted)]">
                  {new Date(featuredPost.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </span>
              </div>
              <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6 text-[var(--text-primary)] group-hover:text-[var(--color-accent-secondary)] dark:group-hover:text-[var(--color-accent)] transition-colors line-clamp-3">
                {featuredPost.data.title}
              </h2>
              <p class="text-[var(--text-muted)] text-lg mb-8 line-clamp-3 leading-relaxed">
                {featuredPost.data.excerpt}
              </p>
              <div class="flex items-center gap-3 mt-auto">
                <div class="w-10 h-10 rounded-full bg-[var(--bg-surface)] flex items-center justify-center font-bold text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)] shrink-0">
                  {featuredPost.data.author.charAt(0)}
                </div>
                <span class="font-medium text-[var(--text-primary)]">{featuredPost.data.author}</span>
              </div>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- Recent Posts Grid -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 mb-24">
      <h3 class="text-2xl font-heading font-bold mb-8 text-[var(--text-primary)]">Latest Articles</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {remainingPosts.map(post => (
          <a href={`/blog/${post.id}`} class="ve-card group flex flex-col h-full overflow-hidden">
            <div class="aspect-video bg-[var(--bg-surface)] relative overflow-hidden">
              <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute top-4 left-4 px-3 py-1 bg-[var(--bg-primary)]/90 backdrop-blur-sm rounded-full text-xs font-medium text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)]">
                {post.data.category}
              </div>
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <h3 class="text-xl font-heading font-bold mb-3 text-[var(--text-primary)] group-hover:text-[var(--color-accent-secondary)] dark:group-hover:text-[var(--color-accent)] transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-[var(--text-muted)] text-sm mb-6 line-clamp-3 leading-relaxed">
                {post.data.excerpt}
              </p>
              <div class="mt-auto flex items-center justify-between text-xs text-[var(--text-muted)] border-t border-gray-100 dark:border-gray-800 pt-4">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full bg-[var(--bg-surface)] flex items-center justify-center font-bold text-[var(--color-accent-secondary)] dark:text-[var(--color-accent)] shrink-0">
                    {post.data.author.charAt(0)}
                  </div>
                  <span>{post.data.author}</span>
                </div>
                <span>{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

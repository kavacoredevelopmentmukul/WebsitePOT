---
import '../styles/global.css';
import FloatingContact from '../components/FloatingContact.astro';
import { organizationSchema } from '../utils/seo';
import { path } from '../utils/paths';

interface Props {
  title: string;
  description?: string;
  image?: string;
  /** Additional JSON-LD objects (Service, FAQPage, BreadcrumbList, WebPage, etc.) */
  schemas?: Record<string, unknown>[];
}

const {
  title,
  description = 'Hire dedicated remote professionals across the Pacific region. Pre-vetted talent in IT, marketing, finance, design, and 50+ domains.',
  image = '/og-image.png',
  schemas = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url);
const allSchemas = [organizationSchema(), ...schemas];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href={path('favicon.svg')} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <title>{title} | Pacific Ocean Tech</title>
    <meta name="title" content={`${title} | Pacific Ocean Tech`} />
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Pacific Ocean Tech`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:site_name" content="Pacific Ocean Tech" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={`${title} | Pacific Ocean Tech`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url)} />

    <link rel="sitemap" href={path('sitemap-index.xml')} />

    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'light';
      })();
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      window.localStorage.setItem('theme', theme || 'light');
    </script>
  </head>
  <body class="antialiased min-h-screen flex flex-col bg-[var(--bg-primary)] text-[var(--text-primary)]">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
    <FloatingContact />
  </body>
</html>

---
// BlogPost.astro — layout for MDX blog posts
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  category: string;
  image?: string;
}

const { title, description, date, author, category, image } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric'
});
---

<BaseLayout title={title} description={description} image={image}>
  <Header />

  <!-- Article breadcrumb -->
  <nav aria-label="Breadcrumb" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-0">
    <ol class="flex items-center gap-2 text-sm text-[var(--text-muted)]">
      <li><a href="/" class="hover:text-[var(--color-accent)] transition-colors">Home</a></li>
      <li><span class="mx-1 opacity-40">/</span></li>
      <li><a href="/blog" class="hover:text-[var(--color-accent)] transition-colors">Blog</a></li>
      <li><span class="mx-1 opacity-40">/</span></li>
      <li class="text-[var(--color-accent)] font-medium truncate max-w-[200px]">{title}</li>
    </ol>
  </nav>

  <main class="pt-10 pb-16">
    <slot />
  </main>

  <Footer />
</BaseLayout>
